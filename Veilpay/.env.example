# ── Server-side only (set these in Vercel -> Project -> Settings -> Environment
#    Variables). No VITE_ prefix, so they are NEVER shipped to the browser. ──

# Resend API key for sending waitlist verification codes. https://resend.com
RESEND_API_KEY="re_Duredhwo_DgYT73fhPGucAS7JUBrKiVrF"

# The "From" address. The domain must be verified in Resend before it can send
# to arbitrary recipients (add Resend's SPF/DKIM DNS records to veilpayapp.com).
WAITLIST_FROM_EMAIL="Veilpay <waitlist@veilpayapp.com>"

# Any long random string. Signs the stateless verification tokens. Rotating it
# invalidates all outstanding (unverified) codes.
WAITLIST_SIGNING_SECRET="ewodekdpowekdokdewpdkpweokdepwodkpowe"

# Discord webhook that receives a ping AFTER an email is verified.
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/1523310100599668746/ZCEzsOAFCkhmDYUfk-VXpf2y5FzxoiIqTLvZ5cl6ZaD0gVMQQukJFREku_3Eml3Vs291"
